# Ignore everything by default
*

# But don't ignore directories (needed so we can unignore files inside them)
!*/

# Track only R scripts
!*.R

# Track R Markdown reports
!*.Rmd

# Track the pipeline map
!pipeline_map.csv

# Track metadata
!Data/Drug_ATC_Categories.csv
!Data/medication_recode.csv
!Data/ps_covariates.csv
!Data/var_name_to_pretty.csv
!Data/column_schema.csv
!Data/column_schema-SF.csv
!Data/column_schema-COSMOS.csv
!Data/DrugClasses.csv
!Data/period_info.csv
!Data/psych_proc_tiers-manualEdit-MPP.csv

# Track data diary
!Data_Diary/prepData-schema.xlsx

# Track the pipeline map generator
!generate_pipeline_map.py

# Track .txt files unless they start with SQL_Query
!*.txt
SQL_Query*.txt
IDs*.txt

# Optional: keep this file tracked (recommended)
!.gitignore

# Jupyter
.ipynb_checkpoints/

# Track CLAUDE.md
!CLAUDE.md

# Track README
!README.md

# Track JSON config files (but not the local config itself)
!*.json
config.json

# ignore error demos
errorDemos/

# renv files
install_dependencies.R
.Rproj.user
!GLP1_DTE-SF.Rproj
!renv.lock
!renv/.gitignore
!renv/activate.R
!.Rprofile
